(defwindow bar []
  :monitor 0
  :exclusive true
  :stacking "fg"
 ; :windowtype "docnk"
  :geometry (geometry :x "0"
                      :y "0"
                      :width "100%"
                    
                      :anchor "top center")
  (centerbox :orientation "h" :halign "fill"
    (left)
    (center)
    (right)))
